# App environment: development | production | test
APP_ENV=development

# Flask secret key. Use a strong random string in production.
SECRET_KEY=change-me-in-production

# Database URL. SQLite is fine locally; use Postgres in production.
DATABASE_URL=sqlite:///companylens.db

# Anthropic API key used in the enrichment phase.
ANTHROPIC_API_KEY=

# HTTP timeout for page fetches in seconds.
REQUEST_TIMEOUT=12

# Maximum number of pages to crawl per website.
MAX_FETCH_PAGES=5

# Maximum bytes accepted from a single fetched page.
MAX_PAGE_BYTES=2000000

# Thread pool size for concurrent page fetching.
SCRAPER_WORKERS=4

# Logging verbosity.
LOG_LEVEL=INFO
